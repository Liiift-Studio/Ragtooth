{
	"name": "ragtooth",
	"version": "1.2.9",
	"description": "Deliberate sawtooth rag for the web — works with React, vanilla JS, or any framework",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "vite build",
		"dev": "vite build --watch",
		"dev:site": "npm run dev & cd site && npm run dev",
		"typecheck": "tsc --noEmit",
		"lint": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui"
	},
	"keywords": [
		"typography",
		"rag",
		"saw-rag",
		"sawtooth-rag",
		"ragtooth",
		"typesetting",
		"text",
		"react",
		"vanilla-js",
		"framework-agnostic",
		"letter-spacing"
	],
	"author": "Quinn Keaveney",
	"license": "MIT",
	"homepage": "https://github.com/quitequinn/Ragtooth#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/quitequinn/Ragtooth.git"
	},
	"bugs": {
		"url": "https://github.com/quitequinn/Ragtooth/issues"
	},
	"sideEffects": false,
	"peerDependencies": {
		"react": ">=17.0.0",
		"react-dom": ">=17.0.0"
	},
	"peerDependenciesMeta": {
		"react": { "optional": true },
		"react-dom": { "optional": true }
	},
	"devDependencies": {
		"next": "16.2.2",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^4.0.0",
		"@vitest/ui": "^1.0.0",
		"happy-dom": "^12.0.0",
		"typescript": "^5.0.0",
		"vite": "^5.0.0",
		"vite-plugin-dts": "^3.9.0",
		"vitest": "^1.0.0"
	}
}
