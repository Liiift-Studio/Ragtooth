{
	"compilerOptions": {
		"target": "ES2018",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2018", "DOM"],
		"jsx": "react-jsx",
		"strict": true,
		"declaration": true,
		"declarationDir": "./dist",
		"skipLibCheck": true,
		"esModuleInterop": true
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"]
}
